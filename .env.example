# Pinara — environment variables
# All Vercel envs set to Production.

NEXT_PUBLIC_SITE_URL=https://pinara.app
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=pinara.app

# Schumann feed (proxy through /api/schumann). If unset, the route falls back
# to the bundled NOAA-derived constants and a synthetic baseline.
SCHUMANN_FEED_URL=

# NOAA SWPC (Phase 3+; Phase 1 ignores)
NOAA_SWPC_URL=https://services.swpc.noaa.gov

# Sentry (anonymous error tracking, Phase 1 enabled per locked decisions)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Phase 4+ — leave blank in Phase 1
ANTHROPIC_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
CLOUDFLARE_WORKER_LICENCE_URL=

# WebRTC (Phase 6)
WEBRTC_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
